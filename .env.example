# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (for AI-generated skill tests; model: deepseek/deepseek-r1-0528)
OPENROUTER_API_KEY=

# Resend (for transactional email: workspace invite, job application, submission, messages)
RESEND_API_KEY=
RESEND_FROM_EMAIL=Codeveria <onboarding@resend.dev>

# App URL (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel (preview deployments for code submissions)
VERCEL_TOKEN=
VERCEL_TEAM_ID=
VERCEL_PROJECT_ID=

# Lemon Squeezy (code unlock payments)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_APP_URL=http://localhost:3000
